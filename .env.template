# .env.template
# Copy this file to .env (for development) or .env.prod (for production)
# and update the values with your specific configuration/secrets.

# ==========================================
# CORE SETTINGS
# ==========================================
# True for Dev, False for Prod
DEBUG=True

# ==========================================
# NETWORKING & CORS
# ==========================================
# Domain for Caddy/Traefik
DOMAIN=localhost
# Used for constructing callback URLs
BACKEND_PUBLIC_URL=http://localhost:8000
FRONTEND_PUBLIC_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ==========================================
# DATABASE (PostgreSQL)
# ==========================================
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=app_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me
# Optional: Connection Pool settings
DB_POOL_SIZE=20
DB_TIMEOUT=30

# ==========================================
# CACHE & BROKER (Redis)
# ==========================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
# Connection string constructed in code usually, but can be explicit:
# CELERY_BROKER_URL=redis://redis:6379/0

# ==========================================
# WORKERS (Celery)
# ==========================================
CELERY_TASK_ALWAYS_EAGER=False
CELERY_RESULT_EXPIRES=3600
CELERY_TASK_TIME_LIMIT=600
CELERY_TASK_SOFT_TIME_LIMIT=500

# ==========================================
# AUTHENTICATION
# ==========================================
JWT_SECRET=change_me_to_a_secure_random_string
JWT_ACCESS_TOKEN_EXPIRATION=15 # in minutes
JWT_REFRESH_TOKEN_EXPIRATION=10080 # in minutes
PKCE_ENABLED=true
MAX_REFRESH_TOKENS=50

# ==========================================
# CLEANUP JOBS
# ==========================================
CLEANUP_REVOKED_TOKENS_RETENTION_MINUTES=10080
# UTC Schedule
CLEANUP_REVOKED_TOKENS_SCHEDULE_HOUR=7
CLEANUP_REVOKED_TOKENS_SCHEDULE_MINUTE=0

# ==========================================
# EXTERNAL SERVICES (Google OAuth)
# ==========================================
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
# Note: Ensure this matches exactly what is in Google Cloud Console
GOOGLE_REDIRECT_URI=http://localhost:5173/login

# ==========================================
# FRONTEND (Vite)
# ==========================================
VITE_API_BASE_URL=http://localhost:8000
# NOTE: Variable expansion (${VAR}) depends on your dotenv loader. 
# If it fails, duplicate the values explicitly below.
VITE_GOOGLE_CLIENT_ID=${GOOGLE_CLIENT_ID}
VITE_GOOGLE_REDIRECT_URI=${GOOGLE_REDIRECT_URI}
VITE_API_PROXY_TARGET=http://fastapi_backend:8000

# ==========================================
# MONITORING (Flower)
# ==========================================
FLOWER_URL_PREFIX=flower
# Generate with: htpasswd -nBC 10 username
# Remember to use double $$ for Docker Compose compatibility
FLOWER_BASIC_AUTH_HASH=$$2a$$14$$...

# ==========================================
# FILE UPLOADS
# ==========================================
MAX_FILES_PER_UPLOAD=10